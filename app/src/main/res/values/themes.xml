<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.DataSync" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorOnPrimary">@color/md_theme_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_onPrimaryContainer</item>

        <item name="colorSecondary">@color/md_theme_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_onSecondaryContainer</item>

        <item name="colorError">@color/md_theme_error</item>
        <item name="colorOnError">@color/md_theme_onError</item>
        <item name="colorErrorContainer">@color/md_theme_errorContainer</item>

        <item name="android:colorBackground">@color/md_theme_background</item>
        <item name="colorOnBackground">@color/md_theme_onBackground</item>
        <item name="colorSurface">@color/md_theme_surface</item>
        <item name="colorOnSurface">@color/md_theme_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_onSurfaceVariant</item>
        <item name="colorOutline">@color/md_theme_outline</item>

        <item name="android:statusBarColor">@color/md_theme_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:navigationBarColor">@color/md_theme_surface</item>

        <item name="materialButtonStyle">@style/Widget.DataSync.Button</item>
        <item name="textInputStyle">@style/Widget.DataSync.TextInputLayout</item>
        <item name="bottomNavigationStyle">@style/Widget.DataSync.BottomNav</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.DataSync.Splash" parent="Theme.DataSync">
        <item name="android:windowBackground">@drawable/bg_splash</item>
        <item name="android:statusBarColor">@color/gradient_start</item>
        <item name="android:navigationBarColor">@color/gradient_end</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

    <!-- ===================== Widgets ===================== -->

    <style name="Widget.DataSync.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/corner_radius_md</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="contentPadding">@dimen/spacing_md</item>
        <item name="cardBackgroundColor">@color/md_theme_surfaceElevated</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.DataSync.Card.Flat" parent="Widget.DataSync.Card">
        <item name="cardElevation">@dimen/elevation_none</item>
    </style>

    <style name="Widget.DataSync.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/corner_radius_sm</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textAllCaps">false</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.DataSync.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">@dimen/corner_radius_sm</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.DataSync.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/corner_radius_sm</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/md_theme_outline</item>
    </style>

    <style name="Widget.DataSync.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_radius_sm</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_radius_sm</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_radius_sm</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_radius_sm</item>
        <item name="boxStrokeColor">@color/md_theme_primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/md_theme_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxBackgroundColor">@color/md_theme_surface</item>
    </style>

    <style name="Widget.DataSync.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">@dimen/corner_radius_xl</item>
        <item name="chipBackgroundColor">@color/md_theme_surface</item>
        <item name="chipStrokeColor">@color/md_theme_outline</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.DataSync.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.DataSync.BottomNav.Indicator</item>
    </style>

    <style name="Widget.DataSync.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/md_theme_primaryContainer</item>
    </style>

    <!-- ===================== Text appearances ===================== -->

    <style name="TextAppearance.DataSync.Headline" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.DataSync.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.DataSync.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.DataSync.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="TextAppearance.DataSync.HeadlineOnPrimary" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.DataSync.BodyOnPrimary" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/white</item>
        <item name="android:alpha">0.85</item>
    </style>
</resources>